# ═══════════════════════════════════════════════════════════════════════════
# WellHeard AI - Environment Configuration
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
HV_HOST=0.0.0.0
HV_PORT=8000
HV_DEBUG=false
HV_API_KEY=vs-your-secure-api-key-here
HV_REDIS_URL=redis://localhost:6379/0

# ── Pipeline Mode: "budget" ($0.021/min) or "quality" ($0.032/min) ────────
HV_DEFAULT_PIPELINE=budget

# ── Deepgram (Required: used for STT in both modes, TTS in budget mode) ──
HV_DEEPGRAM_API_KEY=your-deepgram-key
HV_DEEPGRAM_STT_MODEL=nova-3
HV_DEEPGRAM_TTS_MODEL=aura-asteria-en

# ── Groq (Required for budget mode) ──────────────────────────────────────
HV_GROQ_API_KEY=your-groq-key
HV_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Google Gemini (Required for quality mode) ────────────────────────────
HV_GOOGLE_API_KEY=your-google-key
HV_GEMINI_MODEL=gemini-2.5-flash

# ── Cartesia (Required for quality mode) ─────────────────────────────────
HV_CARTESIA_API_KEY=your-cartesia-key
HV_CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ── Telnyx (Telephony) ──────────────────────────────────────────────────
HV_TELNYX_API_KEY=your-telnyx-key
HV_TELNYX_CONNECTION_ID=your-connection-id
HV_TELNYX_PHONE_NUMBER=+1234567890

# ── LiveKit (Media Server) ──────────────────────────────────────────────
HV_LIVEKIT_URL=ws://localhost:7880
HV_LIVEKIT_API_KEY=your-livekit-key
HV_LIVEKIT_API_SECRET=your-livekit-secret
